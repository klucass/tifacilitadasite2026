---
import "../styles/globals.css";
import favicon from "../assets/images/favicon.png";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TI Facilitada - Fluência em Dados",
  description = "Resumos objetivos e esquematizados de Fluência em Dados para concursos das áreas Fiscal e Controle, com cadernos de questões do TEC Concursos. Acesso imediato e garantia de 7 dias.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
