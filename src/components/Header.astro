---
import logo from "../assets/images/logo.png";
---

<header
  style="position:sticky;top:0;z-index:60;background:rgba(255,255,255,0.85);backdrop-filter:blur(12px);border-bottom:1px solid #ECEAF6"
>
  <div
    style="max-width:1180px;margin:0 auto;padding:0 clamp(18px,5vw,28px);height:68px;display:flex;align-items:center;justify-content:space-between;gap:20px"
  >
    <a href="#topo" style="display:flex;align-items:center">
      <img
        src={logo.src}
        alt="TI Facilitada"
        style="height:38px;display:block;width:auto"
      />
    </a>
    <a
      href="https://app.miblify.com/login/my_library"
      target="_blank"
      rel="noopener"
      style="text-decoration:none;color:#5800FF;font-size:14px;font-weight:700;padding:9px 16px;border:1px solid #C9B8F0;border-radius:9px;white-space:nowrap"
      >Área do aluno</a
    >
  </div>
</header>
