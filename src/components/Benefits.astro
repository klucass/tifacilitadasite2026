<section
  style="max-width:1180px;margin:0 auto;padding:clamp(64px,9vw,104px) clamp(20px,5vw,28px)"
>
  <div style="max-width:680px;margin-bottom:clamp(36px,5vw,48px)">
    <span
      style="display:inline-flex;align-items:center;background:#F0EDFA;color:#5800FF;padding:7px 14px;border-radius:999px;font-size:13px;font-weight:600;margin-bottom:18px"
      >Por que funciona</span
    >
    <h2
      style="font-size:clamp(28px,4.6vw,44px);line-height:1.06;letter-spacing:-0.025em;font-weight:800;margin:0"
    >
      Estudo objetivo, direcionado ao que realmente cai em prova.
    </h2>
  </div>
  <div
    style="display:grid;grid-template-columns:repeat(auto-fit,minmax(248px,1fr));gap:1px;background:#C9B8F0;border:1px solid #C9B8F0;border-radius:18px;overflow:hidden"
  >
    <div
      style="background:#F6F4FC;padding:clamp(28px,4vw,38px) clamp(24px,3vw,32px)"
    >
      <div
        style="font-size:15px;color:#5800FF;font-weight:700;margin-bottom:22px"
      >
        01
      </div>
      <h3
        style="font-size:20px;font-weight:700;letter-spacing:-0.01em;margin:0 0 10px"
      >
        Só o que cai
      </h3>
      <p style="font-size:16px;line-height:1.6;color:#5A5A66;margin:0">
        Conteúdo filtrado a partir de editais e provas recentes da área fiscal e
        de controle. Sem enrolação.
      </p>
    </div>
    <div
      style="background:#F6F4FC;padding:clamp(28px,4vw,38px) clamp(24px,3vw,32px)"
    >
      <div
        style="font-size:15px;color:#5800FF;font-weight:700;margin-bottom:22px"
      >
        02
      </div>
      <h3
        style="font-size:20px;font-weight:700;letter-spacing:-0.01em;margin:0 0 10px"
      >
        Esquematizado
      </h3>
      <p style="font-size:16px;line-height:1.6;color:#5A5A66;margin:0">
        Resumo visual, com fluxogramas e organização inteligente para você
        absorver o máximo em pouco tempo.
      </p>
    </div>
    <div
      style="background:#F6F4FC;padding:clamp(28px,4vw,38px) clamp(24px,3vw,32px)"
    >
      <div
        style="font-size:15px;color:#5800FF;font-weight:700;margin-bottom:22px"
      >
        03
      </div>
      <h3
        style="font-size:20px;font-weight:700;letter-spacing:-0.01em;margin:0 0 10px"
      >
        Cadernos do TEC
      </h3>
      <p style="font-size:16px;line-height:1.6;color:#5A5A66;margin:0">
        Aluas com cadernos de questões para você treinar e se preparar para o
        concurso.
      </p>
    </div>
  </div>
</section>
