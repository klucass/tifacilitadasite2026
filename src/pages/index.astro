---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import BancasStrip from "../components/BancasStrip.astro";
import Benefits from "../components/Benefits.astro";
import { Image } from "astro:assets";
import logo from "../assets/images/logo.png";

const aulaImports = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/aulas/*.png",
  { eager: true },
);

const captions = [
  "Capa",
  "Sumário",
  "Mapa mental",
  "Resumo esquematizado",
  "SQL: comandos",
  "Modelagem de dados",
  "Big Data",
  "Business Intelligence",
  "Machine Learning",
  "Questões comentadas",
  "Caderno de questões",
  "Revisão final",
];

const totalAulas = Object.keys(aulaImports).length;

const gallery = Array.from({ length: totalAulas }, (_, i) => {
  const n = i + 1;
  return {
    id: `mat-${String(n).padStart(2, "0")}`,
    src: aulaImports[`../assets/images/aulas/${n}.png`].default,
    alt: captions[i] ? `Aula ${n} — ${captions[i]}` : `Página ${n} do material`,
  };
});

const faqs = [
  {
    q: "Como eu recebo o material?",
    a: "Assim que a compra é confirmada, você recebe o acesso imediato ao material em PDF para baixar e usar onde e como quiser.",
  },
  {
    q: "É material impresso ou digital?",
    a: "É 100% digital, em PDF. Você lê no celular, tablet ou computador — e, se preferir estudar no papel, pode imprimir à vontade.",
  },
  {
    q: "Os cadernos de questões estão inclusos?",
    a: "Sim. Cada aula inclui cadernos de questões do TEC Concursos para você treinar e aprofundar o conteúdo.",
  },
  {
    q: "Serve para qual concurso?",
    a: "É focado na área Fiscal e de Controle — Sefaz, TCE, TCM, CGU, TCU e outros cargos que cobram fluência em dados no edital.",
  },
  {
    q: "Os resumos são atualizados?",
    a: "Sim. Os materiais são revisados e atualizados conforme os editais mais recentes, para você estudar o conteúdo certo.",
  },
  {
    q: "Preciso saber de TI para começar?",
    a: "Não. O material é feito para iniciantes, com linguagem clara e simples. Você não precisa entender nada de TI para começar.",
  },
  {
    q: "E se eu não gostar?",
    a: "Você tem 7 dias de garantia. Se o material não for o que esperava, basta pedir o reembolso e devolvemos 100% do valor, sem burocracia.",
  },
  {
    q: "Já sou aluno. Onde acesso o material?",
    a: "É só entrar na Área do Aluno com seu login e senha para acessar todo o conteúdo, quando e onde quiser.",
    link: {
      href: "https://app.miblify.com/login/my_library",
      label: "Acessar a Área do Aluno →",
    },
  },
];
